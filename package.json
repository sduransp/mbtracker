{
  "name": "mbtracker",
  "version": "0.1.0",
  "private": false,
  "description": "Local matched betting tracker (Node + SQLite + Vite)",
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "Sergio Durán",
  "license": "MIT",
  "scripts": {
    "postinstall": "echo skip",
    "dev": "concurrently -n server,web -c magenta,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "nodemon --watch server --ext js,json --exec node server/index.js",
    "dev:web": "cd web && vite",
    "build": "cd web && vite build",
    "start": "NODE_ENV=production node server/index.js",
    "smoke": "node scripts/smoke-test.js",
    "export:csv": "node scripts/export-csv.js"
  },
  "keywords": ["matched-betting", "sqlite", "express", "vite", "pnl", "tracking"],
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "nodemon": "^3.0.2",
    "vite": "^5.1.6"
  }
}
